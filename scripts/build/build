#! /bin/bash

start=$(date +%s.%N)

# Define the command to execute
command="yarn build"
command2="rm -rfv ./.next/cache"
script_dir=$(dirname "$(realpath "$0")")

# Go up two levels
parent_dir=$(dirname "$(dirname "$script_dir")")

is_app_dir() {
  local dir_name="$1"
  [[
    "$dir_name" == "main" ||
    "$dir_name" == "web-1" ]]

}
#
## Loop through each directory
for dir in "$parent_dir"/*; do
  # Check if the directory is indeed a directory
  if [ -d "$dir" ] && is_app_dir "$(basename "$dir")"; then
    # Enter the directory
    cd "$dir" || continue

    # Execute the command
    echo "Executing '$command' in $(pwd)"
    $command

    echo "Executing '$command2' in $(pwd)"
    $command2
    # Return to the original directory
    cd ..
  fi
done

echo 'Build OK.'

end=$(date +%s.%N)
runtime=$(echo "$end - $start" | bc)
echo "BUILD Elapsed time: ${runtime} seconds"
